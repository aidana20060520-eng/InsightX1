# InsightX environment variables.
#
# Copy this file to `.env.local` for local dev, or paste these names into
# Vercel's Project Settings → Environment Variables for production.
# Never commit a file containing real values.

# ---------- Supabase ----------
# https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---------- Clerk (auth) ----------
# https://dashboard.clerk.com → Your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ---------- Notion OAuth ----------
# https://www.notion.so/my-integrations → New integration (public OAuth)
# In production, set NOTION_REDIRECT_URI to https://your-domain.vercel.app/api/notion/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:3000/api/notion/callback

# ---------- LLM (Groq) ----------
# https://console.groq.com/keys (free, no credit card)
GROQ_API_KEY=gsk_...
# Optional: override default model. Free options:
#   llama-3.3-70b-versatile  (default, smartest)
#   llama-3.1-8b-instant     (fastest)
#   gemma2-9b-it
# GROQ_MODEL=llama-3.3-70b-versatile

# ---------- App ----------
# Public URL of your deployed app. In production set this to your Vercel
# domain (e.g. https://insightx-yourname.vercel.app).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 32-byte (64 hex char) key used to AES-256-GCM encrypt Notion tokens at
# rest in Supabase. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# ---------- Upstash Redis (rate limiting) ----------
# Free at https://upstash.com → create a Redis database → REST API tab.
# Without these, rate limiting is DISABLED (chat works but no abuse protection).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- Cron (scheduled Notion re-sync) ----------
# Random secret. Vercel Cron sends this in the Authorization header so we
# can verify the request actually came from Vercel and not the public
# internet. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
